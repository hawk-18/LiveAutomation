<Window x:Class="WpfAppLiveAutomation.ReplaySettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="直播回放设置" Height="600" Width="600"
        FontFamily="Microsoft YaHei UI" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF5C6BC0"/>
        <SolidColorBrush x:Key="LightBackground" Color="#FFF8F9FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE0E0E0"/>

        <!-- 标签样式 -->
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,12,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- 输入框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9FA8DA"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 多行文本框特殊样式 -->
        <Style x:Key="MultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="120"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- 按钮样式 -->
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7986CB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF5C6BC0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFF8F9FA"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F1F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl样式 -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- TabItem样式 -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="#616161"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="Transparent">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" 
                                            HorizontalAlignment="Center" 
                                            ContentSource="Header" Margin="6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource LightBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <Border Grid.Row="0" Background="Transparent" Margin="0,0,0,16">
                <TextBlock Text="直播回放设置" 
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryColor}"/>
            </Border>

            <!-- 主内容区域 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <TabControl>
                    <!-- 修改后的 XAML 片段 -->
                    <TabItem Header="抖音">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                            <StackPanel>
                                <Label Content="抖音标题"/>
                                <TextBox x:Name="douyinTitleTextBox" x:FieldModifier="public" Text="{Binding DouyinTitle}"/>

                                <Label Content="抖音描述"/>
                                <TextBox x:Name="douyinDescTextBox" x:FieldModifier="public" Style="{StaticResource MultilineTextBox}" 
                     Text="{Binding DouyinDescription}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="哔哩哔哩">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                            <StackPanel>
                                <Label Content="哔哩哔哩标题"/>
                                <TextBox x:Name="bilibiliTitleTextBox" x:FieldModifier="public" Text="{Binding BilibiliTitle}"/>

                                <Label Content="哔哩哔哩描述"/>
                                <TextBox x:Name="bilibiliDescTextBox" x:FieldModifier="public" Style="{StaticResource MultilineTextBox}" 
                     Text="{Binding BilibiliDescription}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="微信视频号">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                            <StackPanel>
                                <Label Content="微信视频号标题"/>
                                <TextBox x:Name="wechatTitleTextBox" x:FieldModifier="public" Text="{Binding WechatVideoTitle}"/>

                                <Label Content="微信视频号描述"/>
                                <TextBox x:Name="wechatDescTextBox" x:FieldModifier="public" Style="{StaticResource MultilineTextBox}" 
                     Text="{Binding WechatVideoDescription}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="公众号">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                            <StackPanel>
                                <Label Content="公众号标题"/>
                                <TextBox x:Name="officialTitleTextBox" x:FieldModifier="public" Text="{Binding OfficialAccountTitle}"/>

                                <Label Content="公众号描述"/>
                                <TextBox x:Name="officialDescTextBox" x:FieldModifier="public" Style="{StaticResource MultilineTextBox}" 
                     Text="{Binding OfficialAccountDescription}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Border>

            <!-- 底部按钮区域 -->
            <Border Grid.Row="2" Background="Transparent" Margin="0,16,0,0" Padding="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Click="CancelButton_Click" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="保存" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
