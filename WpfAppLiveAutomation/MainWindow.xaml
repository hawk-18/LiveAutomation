<Window x:Class="WpfAppLiveAutomation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppLiveAutomation"
        mc:Ignorable="d"
        Title="多平台定时直播任务工具" 
        WindowStartupLocation="CenterScreen"
        Height="900" Width="1400"
        MinWidth="900" MinHeight="650"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF5C6BC0"/>
        <SolidColorBrush x:Key="LightBackground" Color="#FFF8F9FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="TextColor" Color="#424242"/>
        <!-- 阴影效果 -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="1" Opacity="0.08" Direction="270"/>
        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7986CB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF5C6BC0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Background" Value="#FFF8F9FA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F1F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 操作按钮样式 -->
        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF546E7A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF455A64"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF37474F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF78909C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF607D8B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF546E7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 路径文本样式 -->
        <Style x:Key="PathTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding}"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Padding" Value="0,0,0,8"/>
        </Style>

        <!-- 表格样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F7FA"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#ECEFF1"/>
                        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource LightBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <!-- 主标题卡片 -->
                <RowDefinition Height="Auto"/>

                <!-- 正在执行任务标题 -->
                <RowDefinition Height="Auto"/>
                <!-- 正在执行任务表格（固定高度仅显示两行） -->
                <RowDefinition Height="80"/>

                <!-- 待执行任务区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 待执行任务表格 -->
                <RowDefinition Height="1.5*"/>

                <!-- 分隔区域 -->
                <RowDefinition Height="Auto"/>

                <!-- 已执行任务标题 -->
                <RowDefinition Height="Auto"/>
                <!-- 已执行任务表格 -->
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>

            <!-- 主标题卡片 -->
            <Border Grid.Row="0" CornerRadius="6" Background="{StaticResource CardBackground}"
                    Margin="0,0,0,16" Padding="20,15" 
                    Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="多平台定时直播任务工具" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryColor}"/>
                    <TextBlock Text="v1.0" Margin="10,5,0,0" Foreground="#78909C" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- 正在执行任务标题 -->
            <Label Grid.Row="1" Content="正在执行直播任务" 
                   Style="{StaticResource SectionTitle}" Margin="0,0,0,5"/>

            <!-- 正在执行任务表格（高度固定为80像素，仅显示两行） -->
            <Border Grid.Row="2" CornerRadius="6" Background="#FFF0F7FF"
                    Padding="1" Effect="{StaticResource CardShadow}">
                <DataGrid x:Name="executingTasksGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          MaxHeight="80" Margin="0,5,0,4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务名称" Binding="{Binding TaskName}" Width="1.5*" MinWidth="120"/>
                        <DataGridTextColumn Header="直播标题" Binding="{Binding LiveTitle}" Width="2*" MinWidth="150"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="平台" Binding="{Binding Platform}" Width="1*" MinWidth="90"/>

                        <DataGridTemplateColumn Header="操作" Width="1*" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="中止" 
                                            Style="{StaticResource DeleteButtonStyle}"
                                            Click="AbortButton_Click"
                                            Tag="{Binding Id}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 待执行任务区域 -->
            <Border Grid.Row="3" Background="Transparent" CornerRadius="4">
                <DockPanel>
                    <Label DockPanel.Dock="Left" Content="待执行直播任务" 
                           Style="{StaticResource SectionTitle}"/>
                    <Button DockPanel.Dock="Right" Content="新增直播任务" 
                            HorizontalAlignment="Right" MinWidth="120"
                            Style="{StaticResource PrimaryButton}"
                            Click="Button_Click"/>
                </DockPanel>
            </Border>

            <!-- 待执行任务表格 -->
            <Border Grid.Row="4" CornerRadius="6" Background="{StaticResource CardBackground}"
                    Padding="1" Effect="{StaticResource CardShadow}">
                <DataGrid x:Name="pendingTasksGrid"
                      SelectionChanged="DataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务名称" Binding="{Binding TaskName}" Width="1.5*" MinWidth="120"/>
                        <DataGridTextColumn Header="直播标题" Binding="{Binding LiveTitle}" Width="2*" MinWidth="150"/>
                        <DataGridTextColumn Header="准备时间" Binding="{Binding PreparationTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="平台" Binding="{Binding Platform}" Width="1*" MinWidth="90"/>

                        <!-- 优化后的海报路径列 -->
                        <DataGridTemplateColumn Header="封面路径" Width="2.5*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PosterAddress}" Style="{StaticResource PathTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 优化后的视频路径列 -->
                        <DataGridTemplateColumn Header="视频路径" Width="2.5*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding VideoAddress}" Style="{StaticResource PathTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="创建人" Binding="{Binding Creator}" Width="0.8*" MinWidth="70"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime}" Width="1.5*" MinWidth="140"/>
                        <DataGridTextColumn Header="修改人" Binding="{Binding Editor}" Width="0.8*" MinWidth="70"/>
                        <DataGridTextColumn Header="修改时间" Binding="{Binding EditorTime}" Width="1.5*" MinWidth="140"/>
                        <DataGridTemplateColumn Header="操作" Width="1.2*" MinWidth="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="修改" Style="{StaticResource EditButtonStyle}" 
                                                Click="EditButton_Click" Tag="{Binding}"/>
                                        <Button Content="删除" Style="{StaticResource DeleteButtonStyle}" 
                                                Click="DeleteButton_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 分隔区域 -->
            <Grid Grid.Row="5" Margin="0,5,0,10">
                <Rectangle Height="1" Fill="{StaticResource BorderColor}" VerticalAlignment="Center"/>
                <TextBlock Text="历史任务记录" HorizontalAlignment="Center" Background="{StaticResource LightBackground}" 
                           Padding="10,0" Foreground="{StaticResource TextColor}" FontWeight="SemiBold" Margin="0,6,0,-6"/>
            </Grid>

            <!-- 已执行任务标题 -->
            <Label Grid.Row="6" Content="已执行直播任务" 
                   Style="{StaticResource SectionTitle}" Margin="0,10,0,5"/>

            <!-- 已执行任务表格 -->
            <Border Grid.Row="7" CornerRadius="6" Background="{StaticResource CardBackground}"
                    Padding="1" Effect="{StaticResource CardShadow}">
                <DataGrid x:Name="completedTasksGrid">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务名称" Binding="{Binding TaskName}" Width="1.5*" MinWidth="120"/>
                        <DataGridTextColumn Header="直播标题" Binding="{Binding LiveTitle}" Width="2*" MinWidth="150"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime}" Width="1.5*" MinWidth="130"/>
                        <DataGridTextColumn Header="平台" Binding="{Binding Platform}" Width="1*" MinWidth="90"/>

                        <!-- 优化后的海报路径列 -->
                        <DataGridTemplateColumn Header="封面路径" Width="2.5*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PosterAddress}" Style="{StaticResource PathTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 优化后的视频路径列 -->
                        <DataGridTemplateColumn Header="视频路径" Width="2.5*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding VideoAddress}" Style="{StaticResource PathTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="创建人" Binding="{Binding Creator}" Width="0.8*" MinWidth="70"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime}" Width="1.5*" MinWidth="140"/>
                        <DataGridTextColumn Header="修改人" Binding="{Binding Editor}" Width="0.8*" MinWidth="70"/>
                        <DataGridTextColumn Header="修改时间" Binding="{Binding EditorTime}" Width="1.5*" MinWidth="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
