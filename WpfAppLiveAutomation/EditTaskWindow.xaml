<Window x:Class="WpfAppLiveAutomation.EditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改任务" Height="650" Width="900"
        FontFamily="Microsoft YaHei UI" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 修复：添加缺失的颜色资源 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF5C6BC0"/>
        <SolidColorBrush x:Key="LightBackground" Color="#FFF8F9FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE0E0E0"/>
        
        <!-- 修复：添加完整的按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7986CB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF5C6BC0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 修复：添加SecondaryButton样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Background" Value="#FFF8F9FA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F1F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 修复：添加SmallButton样式 -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <!-- 修复：添加输入框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9FA8DA"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 修复：添加日期选择器样式 -->
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- 修复：添加单选按钮样式 -->
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- 修复：添加复选框样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- 修复：添加标签样式 -->
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- 修复：添加分组框样式 -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource LightBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <TextBlock Text="修改直播任务" 
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource PrimaryColor}"/>

            <!-- 主内容区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2">
                <StackPanel>
                    <!-- 基础信息分组 - 添加浏览按钮 -->
                    <GroupBox Header="基础信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 任务名称 -->
                            <Label Content="任务名称:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding TaskName}"/>

                            <!-- 直播标题 -->
                            <Label Content="直播标题:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding LiveTitle}"/>

                            <!-- 视频路径 + 浏览按钮 -->
                            <Label Content="视频路径:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtVideoPath" Grid.Row="2" Grid.Column="1" Text="{Binding VideoAddress}"/>
                            <Button Grid.Row="2" Grid.Column="2" 
                                    Content="浏览..." 
                                    Click="BrowseVideoButton_Click"
                                    Style="{StaticResource SmallButton}"/>

                            <!-- 封面路径 + 浏览按钮 -->
                            <Label Content="封面路径:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPosterPath" Grid.Row="3" Grid.Column="1" Text="{Binding PosterAddress}"/>
                            <Button Grid.Row="3" Grid.Column="2" 
                                    Content="浏览..." 
                                    Click="BrowsePosterButton_Click"
                                    Style="{StaticResource SmallButton}"/>
                        </Grid>
                    </GroupBox>

                    <!-- 时间设置分组 - 改为三列布局 -->
                    <GroupBox Header="时间设置">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 准备时间 -->
                            <StackPanel Grid.Column="0" Margin="5">
                                <Label Content="准备时间 (建议开始前30分钟)"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker x:Name="prepDatePicker" Width="140"/>
                                    <TextBox x:Name="prepTimeTextBox" Width="90" Margin="10,0,0,0" 
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 开始时间 -->
                            <StackPanel Grid.Column="1" Margin="5">
                                <Label Content="开始时间"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker x:Name="startDatePicker" Width="140"/>
                                    <TextBox x:Name="startTimeTextBox" Width="90" Margin="10,0,0,0" 
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 结束时间 -->
                            <StackPanel Grid.Column="2" Margin="5">
                                <Label Content="结束时间"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker x:Name="endDatePicker" Width="140"/>
                                    <TextBox x:Name="endTimeTextBox" Width="90" Margin="10,0,0,0" 
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- 平台选择分组 -->
                    <GroupBox Header="发布平台">
                        <UniformGrid Columns="3" HorizontalAlignment="Center">
                            <CheckBox x:Name="cbBilibili" Content="哔哩哔哩"/>
                            <CheckBox x:Name="cbDouyin" Content="抖音"/>
                            <CheckBox x:Name="cbWeChat" Content="微信视频号"/>
                        </UniformGrid>
                    </GroupBox>

                    <!-- 人员信息分组 - 添加创建人信息 -->
                    <GroupBox Header="人员信息">
                        <StackPanel>
                            <!-- 创建人信息(只读) -->
                            <StackPanel>
                                <Label Content="创建人"/>
                                <TextBlock Text="{Binding Creator}" Margin="10,0" FontSize="14"/>
                                <Label Content="创建时间" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding CreateTime}" Margin="10,0" FontSize="14"/>
                            </StackPanel>
                            
                            <!-- 修改人选择 -->
                            <Label Content="修改人" Margin="0,12,0,0"/>
                            <WrapPanel>
                                <RadioButton x:Name="rbEditor1" Content="陈秋颖" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor2" Content="周悦来" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor3" Content="张园园47" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor4" Content="关昊8" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor5" Content="周宇超7" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor6" Content="杨德志9" GroupName="Editor"/>
                                <RadioButton x:Name="rbEditor7" Content="孙浩凱" GroupName="Editor"/>
                            </WrapPanel>
                            
                            <!-- 修改时间(自动生成) -->
                            <Label Content="修改时间" Margin="0,12,0,0"/>
                            <TextBlock x:Name="txtEditTime" Margin="10,0" FontSize="14"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
            <!-- 在适当位置添加回放预览区域 -->


            <!-- 按钮区域 -->
            <Border Grid.Row="2" Background="Transparent" Margin="0,16,0,0" Padding="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="直播回放设置" Width="120" 
                            Click="ReplaySettingButton_Click" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="保存" Click="SaveButton_Click" Style="{StaticResource PrimaryButton}"/>
                    <Button Content="取消" Click="CancelButton_Click" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
